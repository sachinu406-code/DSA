Question 1
Write a program to Linear search
#include <stdio.h>

int main() {
    int arr[100], n, i, search, found = 0;

    printf("Enter the size of array: ");
    scanf("%d", &n);

    // Input array elements
    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Element to search
    printf("Enter element to search: ");
    scanf("%d", &search);

    // Linear search
    for (i = 0; i < n; i++) {
        if (arr[i] == search) {
            found = 1;
            break;
        }
    }

    if (found)
        printf("%d found at position %d\n", search, i + 1);
    else
        printf("%d not found in array\n", search);

    return 0;
}
Question 2
Write a program to Frequency of an element
#include <stdio.h>

int main() {
    int arr[100], n, i, element, count = 0;

    printf("Enter the size of array: ");
    scanf("%d", &n);

    // Input array elements
    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Element to find frequency
    printf("Enter element to find frequency: ");
    scanf("%d", &element);

    // Count frequency
    for (i = 0; i < n; i++) {
        if (arr[i] == element)
            count++;
    }

    printf("Frequency of %d = %d times\n", element, count);

    return 0;
}
