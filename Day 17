Question 1
Write a program to Merge arrays
#include <stdio.h>

int main() {
    int arr1[100], arr2[100], arr3[200];
    int n1, n2, i, j;

    // Input first array
    printf("Enter size of first array: ");
    scanf("%d", &n1);

    printf("Enter %d elements of first array:\n", n1);
    for (i = 0; i < n1; i++) {
        scanf("%d", &arr1[i]);
    }

    // Input second array
    printf("Enter size of second array: ");
    scanf("%d", &n2);

    printf("Enter %d elements of second array:\n", n2);
    for (i = 0; i < n2; i++) {
        scanf("%d", &arr2[i]);
    }

    // Merge arrays
    for (i = 0; i < n1; i++) {
        arr3[i] = arr1[i];
    }

    for (j = 0; j < n2; j++) {
        arr3[i] = arr2[j];
        i++;
    }

    // Display merged array
    printf("Merged array is:\n");
    for (i = 0; i < n1 + n2; i++) {
        printf("%d ", arr3[i]);
    }

    return 0;
}
Question 2
Write a program to Union of arrays
#include <stdio.h>

int main() {
    int arr1[100], arr2[100], arr3[200];
    int n1, n2, i, j, k = 0, flag;

    // Input first array
    printf("Enter size of first array: ");
    scanf("%d", &n1);

    printf("Enter %d elements of first array:\n", n1);
    for (i = 0; i < n1; i++) {
        scanf("%d", &arr1[i]);
    }

    // Input second array
    printf("Enter size of second array: ");
    scanf("%d", &n2);

    printf("Enter %d elements of second array:\n", n2);
    for (i = 0; i < n2; i++) {
        scanf("%d", &arr2[i]);
    }

    // Copy first array elements to union array
    for (i = 0; i < n1; i++) {
        arr3[k++] = arr1[i];
    }

    // Add second array elements if not already present
    for (i = 0; i < n2; i++) {
        flag = 0;

        for (j = 0; j < k; j++) {
            if (arr2[i] == arr3[j]) {
                flag = 1;
                break;
            }
        }

        if (flag == 0) {
            arr3[k++] = arr2[i];
        }
    }

    // Display union array
    printf("Union of arrays is:\n");
    for (i = 0; i < k; i++) {
        printf("%d ", arr3[i]);
    }

    return 0;
} 
Question 3
Write a program to Intersection of arrays
#include <stdio.h>

int main() {
    int arr1[100], arr2[100];
    int n1, n2, i, j;

    // Input first array
    printf("Enter size of first array: ");
    scanf("%d", &n1);

    printf("Enter %d elements of first array:\n", n1);
    for (i = 0; i < n1; i++) {
        scanf("%d", &arr1[i]);
    }

    // Input second array
    printf("Enter size of second array: ");
    scanf("%d", &n2);

    printf("Enter %d elements of second array:\n", n2);
    for (i = 0; i < n2; i++) {
        scanf("%d", &arr2[i]);
    }

    // Find intersection
    printf("Intersection of arrays is:\n");

    for (i = 0; i < n1; i++) {
        for (j = 0; j < n2; j++) {
            if (arr1[i] == arr2[j]) {
                printf("%d ", arr1[i]);
                break;
            }
        }
    }

    return 0;
} 
Question 4
Write a program to Find common elements.
#include <stdio.h>

int main() {
    int arr1[100], arr2[100];
    int n1, n2, i, j;

    // Input first array
    printf("Enter size of first array: ");
    scanf("%d", &n1);

    printf("Enter %d elements of first array:\n", n1);
    for (i = 0; i < n1; i++) {
        scanf("%d", &arr1[i]);
    }

    // Input second array
    printf("Enter size of second array: ");
    scanf("%d", &n2);

    printf("Enter %d elements of second array:\n", n2);
    for (i = 0; i < n2; i++) {
        scanf("%d", &arr2[i]);
    }

    // Find common elements
    printf("Common elements are:\n");

    for (i = 0; i < n1; i++) {
        for (j = 0; j < n2; j++) {
            if (arr1[i] == arr2[j]) {
                printf("%d ", arr1[i]);
                break;
            }
        }
    }

