Question 1
Q37	Write a program to Print star pyramid.
    *
   ***
  *****
 *******
*********	
#include <stdio.h>

int main() {
    int i, j, rows = 5;

    for (i = 1; i <= rows; i++) {

        // Print spaces
        for (j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print stars
        for (j = 1; j <= (2 * i - 1); j++) {
            printf("*");
        }

        // Move to next line
        printf("\n");
    }

    return 0;
}
