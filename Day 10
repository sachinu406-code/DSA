Q38	Write a program to Print reverse pyramid.
*********
 *******
  *****
   ***
    *	
#include <stdio.h>

int main() {
    int i, j, rows = 5;

    for (i = rows; i >= 1; i--) {

        // Print leading spaces
        for (j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print stars
        for (j = 1; j <= (2 * i - 1); j++) {
            printf("*");
        }

        // Move to next line
        printf("\n");
    }

    return 0;
}
Question 3
Q39	Write a program to Print number pyramid.
    1
   121
  12321
 1234321
123454321
#include <stdio.h>

int main() {
    int i, j, rows = 5;

    for (i = 1; i <= rows; i++) {

        // Print leading spaces
        for (j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print increasing numbers
        for (j = 1; j <= i; j++) {
            printf("%d", j);
        }

        // Print decreasing numbers
        for (j = i - 1; j >= 1; j--) {
            printf("%d", j);
        }

        printf("\n");
    }

    return 0;
}
Question 4
Write a program to Print character pyramid.
      A
   ABA
  ABCBA
 ABCDCBA
ABCDEDCBA
#include <stdio.h>

int main() {
    int i, j, rows = 5;
    char ch;

    for (i = 1; i <= rows; i++) {

        // Print leading spaces
        for (j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Print increasing characters
        ch = 'A';
        for (j = 1; j <= i; j++) {
            printf("%c", ch);
            ch++;
        }

        // Print decreasing characters
        ch -= 2;
        while (ch >= 'A') {
            printf("%c", ch);
            ch--;
        }

        printf("\n");
    }

    return 0;
}

