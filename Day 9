Question 3
Write a program to Print repeated character pattern.
A
BB
CCC
DDDD
EEEEE
#include <stdio.h>

int main() {
    int i, j, rows;

    printf("Enter the number of rows: ");
    scanf("%d", &rows);

    for (i = 1; i <= rows; i++) {
        for (j = 1; j <= i; j++) {
            printf("%c", 'A' + i - 1);
        }
        printf("\n");
    }

    return 0;
}
Question 4 
Write a program to Print hollow square pattern.
*****
*      *
*      *
*      *
*****
#include <stdio.h>

int main() {
    int i, j, rows;

    printf("Enter the size of the square: ");
    scanf("%d", &rows);

    for (i = 1; i <= rows; i++) {
        for (j = 1; j <= rows; j++) {
            if (i == 1 || i == rows || j == 1 || j == rows)
                printf("*");
            else
                printf(" ");
        }
        printf("\n");
    }

    return 0;
}
